@using CarRental.Dal

@model List<Vehicle>;

@{
    ViewData["Title"] = "Vehicles";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-itmes-center mb-4">
        <h1 class="h2 mb-0">Birds</h1>
        <a asp-controller="Home" asp-action="addEditVehicle" class="btn btn-success">+ Add Vehicle</a>
    </div>
</div>

    <table class="table table-striped table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Brand</th>
                <th>Year</th>
                <th>Mileage</th>
                <th>Price</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr>
                    <td>@Model[i].ID</td>
                    <td>@Model[i].brand</td>
                    <td>@Model[i].year</td>
                    <td>@Model[i].mileage</td>
                    <td>@Model[i].price</td>
                    <td>
                        <a asp-controller="Home" asp-action="addEditVehicle"
                        asp-route-id="@Model[i].ID"
                        class="btn btn-sm btn-warning me-1">Edit</a>

                        <a asp-controller="Home" asp-action="deleteVehicle"
                        asp-route-id="@Model[i].ID"
                        class="btn btn-sm btn-danger"
                        onclick="return confirm('Delete this vehicle?')">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
